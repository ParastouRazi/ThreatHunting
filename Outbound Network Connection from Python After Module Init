event.type = "Network"
AND (
    src.process.name = "python.exe"
    OR src.process.name = "python3.exe"
)
AND src.process.cmdline contains "-m"
AND src.process.cmdline contains "init"
AND (
    dst.port.number = 4444
    OR dst.port.number = 1337
    OR dst.port.number = 9001
    OR dst.port.number = 9002
    OR dst.port.number = 5555
    OR dst.port.number = 6666
    OR dst.port.number = 7777
    OR dst.port.number = 8888
)
